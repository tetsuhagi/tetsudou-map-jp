# Cloudflare Pages _headers
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

# Global security headers — applied to every response.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin

# HTML entry point: never cache. The browser always fetches the latest
# index.html, which references the current src/app.js?v=N.
/
  Cache-Control: public, max-age=0, must-revalidate

/index.html
  Cache-Control: public, max-age=0, must-revalidate

# Everything fetched via the ?v=N cache buster (JS modules, CSV timetables,
# JSON geometry, icon PNGs) can be cached forever and marked immutable.
# Bumping V (see src/data.js) invalidates automatically because the URL
# itself changes — old cached copies are simply never requested again.
/src/*
  Cache-Control: public, max-age=31536000, immutable

/data/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable
