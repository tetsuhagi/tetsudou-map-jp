# Cloudflare Pages redirects
# Docs: https://developers.cloudflare.com/pages/configuration/redirects/

# Domain consolidation: tetsudou-map-jp.pages.dev のすべてのアクセスを
# 正規ドメイン tetsudou-map.com へ 301 リダイレクト。
# SEO評価を正規ドメインに集約するための重要なルール。
# Cloudflare Pages の _redirects は HOST 付きフルURLマッチをサポートする。
https://tetsudou-map-jp.pages.dev/* https://tetsudou-map.com/:splat 301!

# .html 付きの URL は、拡張子なしの正規 URL に 301 で寄せる。
# /about.html を直接叩いた場合に重複コンテンツになるのを防ぐ。
/index.html       /            301
/about.html       /about       301
/privacy.html     /privacy     301
/terms.html       /terms       301
/faq.html         /faq         301
/contact.html     /contact     301

# /routes/ 配下も同様にクリーンURL寄せ
/routes/sunrise-seto.html  /routes/sunrise-seto  301
/routes/sunrise-izumo.html /routes/sunrise-izumo 301
/routes/index.html         /routes/              301
